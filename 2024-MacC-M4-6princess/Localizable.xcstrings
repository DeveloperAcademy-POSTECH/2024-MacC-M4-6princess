          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您确定要删除此框架吗？"
          }
        }
      }
    },
    "이미지 렌더링에 실패했습니다. 다시 시도해주세요." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
