    "종료 시 편집된 내용은 저장되지 않습니다." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند الإغلاق، لن يتم حفظ التعديلات."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you exit now, your work will not be saved."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika keluar sekarang, perubahanmu tidak akan disimpan."
