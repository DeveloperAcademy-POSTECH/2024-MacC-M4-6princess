    "이 앱은 세로 화면에서 더 좋은 경험을 제공합니다.\n세로 화면 고정을 활성화해주세요." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يوفر هذا التطبيق تجربة أفضل في وضع الشاشة العمودية.\nيرجى تفعيل قفل الشاشة العمودية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app works best in portrait mode.\nPlease enable portrait orientation."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikasi ini bekerja dengan baik dalam mode potret.\nHarap aktifkan orientasi potret."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリは縦向きの方がより良い体験を提供します。\n縦向きの固定を有効にしてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此应用在竖屏模式下提供更好的体验。\n请启用竖屏锁定。"
          }
        }
      }
    },
    "이 프레임을 삭제할까요?" : {
      "comment" : "단복수",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل ترغب في حذف الإطار؟\n"
